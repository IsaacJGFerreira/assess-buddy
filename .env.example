# Segredos das Edge Functions. Cadastre-os em Lovable Cloud > Secrets.
# Não use o prefixo VITE_, pois esses valores não podem ficar expostos no navegador.
GOOGLE_GMAIL_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_GMAIL_CLIENT_SECRET=seu-client-secret
GMAIL_TOKEN_ENCRYPTION_KEY=uma-chave-aleatoria-longa-e-exclusiva

# Opcional: origens adicionais, separadas por vírgula, além dos domínios padrão do projeto.
APP_ALLOWED_ORIGINS=https://seu-dominio.com

# Firebase (front-end). Preencha com os valores do console do Firebase.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_STORAGE_BUCKET=

# Firebase Data Connect
VITE_DATA_CONNECT_LOCATION=southamerica-east1
VITE_DATA_CONNECT_SERVICE_ID=assess-buddy
VITE_DATA_CONNECT_CONNECTOR_ID=app
